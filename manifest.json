{
  "manifest_version": 3,
  "name": "Kinopoisk .ru → .cx",
  "version": "1.0",
  "description": "Adds a button to open kinopoisk.cx",

  "browser_specific_settings": {
    "gecko": {
      "id": "addon@your-email.com", 
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.kinopoisk.ru/film/*",
        "*://*.kinopoisk.ru/series/*"
      ],
      "js": ["content.js"]
    }
  ]
}
